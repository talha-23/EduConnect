@page "/admin/courses"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using EduConnect.Services.Interfaces
@using EduConnect.Models
@inject ICourseService CourseService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Course Management</h2>
        <button class="btn btn-primary" @onclick="ShowAddModal">
            <i class="bi bi-plus-circle"></i> Add New Course
        </button>
    </div>
    
    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var course in courses)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">@course.Code - @course.Title</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                <strong>Credits:</strong> @course.CreditHours<br />
                                <strong>Instructor:</strong> @course.Instructor<br />
                                <strong>Capacity:</strong> @course.CurrentEnrollment / @course.MaxCapacity<br />
                                <strong>Status:</strong>
                                <span class="badge @GetStatusBadgeClass(course.EnrollmentStatus)">
                                    @course.EnrollmentStatus
                                </span>
                            </p>
                            <div class="progress mb-2">
                                <div class="progress-bar @GetProgressBarClass(course.GetEnrollmentPercentage())"
                                     style="width: @course.GetEnrollmentPercentage()%">
                                    @course.GetEnrollmentPercentage().ToString("F0")%
                                </div>
                            </div>
                            <p class="small text-muted">@course.Description</p>
                        </div>
                        <div class="card-footer">
                            <button class="btn btn-sm btn-warning me-1" @onclick="() => EditCourse(course)">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteCourse(course.Id)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    
    <!-- Add/Edit Modal -->
    @if (showModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@(isEditing ? "Edit Course" : "Add Course")</h5>
                        <button type="button" class="btn-close" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(modalError))
                        {
                            <div class="alert alert-danger">@modalError</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Course Code</label>
                            <input type="text" class="form-control" @bind="currentCourse.Code" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Course Title</label>
                            <input type="text" class="form-control" @bind="currentCourse.Title" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Credit Hours</label>
                            <input type="number" class="form-control" @bind="currentCourse.CreditHours" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Max Capacity</label>
                            <input type="number" class="form-control" @bind="currentCourse.MaxCapacity" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Instructor</label>
                            <input type="text" class="form-control" @bind="currentCourse.Instructor" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="3" @bind="currentCourse.Description"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="SaveCourse">Save</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Course> courses = new();
    private bool isLoading = true;
    private bool showModal = false;
    private bool isEditing = false;
    private Course currentCourse = new();
    private string modalError = string.Empty;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadCourses();
    }
    
    private async Task LoadCourses()
    {
        isLoading = true;
        courses = await CourseService.GetAllCoursesAsync();
        isLoading = false;
        StateHasChanged();
    }
    
    private void ShowAddModal()
    {
        currentCourse = new Course();
        isEditing = false;
        modalError = string.Empty;
        showModal = true;
    }
    
    private void EditCourse(Course course)
    {
        currentCourse = new Course
        {
            Id = course.Id,
            Code = course.Code,
            Title = course.Title,
            CreditHours = course.CreditHours,
            MaxCapacity = course.MaxCapacity,
            Instructor = course.Instructor,
            Description = course.Description
        };
        isEditing = true;
        modalError = string.Empty;
        showModal = true;
    }
    
    private async Task SaveCourse()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(currentCourse.Code))
                throw new Exception("Course code is required");
            
            if (string.IsNullOrWhiteSpace(currentCourse.Title))
                throw new Exception("Course title is required");
            
            if (currentCourse.CreditHours <= 0)
                throw new Exception("Credit hours must be greater than 0");
            
            if (currentCourse.MaxCapacity <= 0)
                throw new Exception("Max capacity must be greater than 0");
            
            if (isEditing)
            {
                await CourseService.UpdateCourseAsync(currentCourse);
                await ShowAlert("Course updated successfully!", "success");
            }
            else
            {
                await CourseService.AddCourseAsync(currentCourse);
                await ShowAlert("Course added successfully!", "success");
            }
            
            CloseModal();
            await LoadCourses();
        }
        catch (Exception ex)
        {
            modalError = ex.Message;
        }
    }
    
    private async Task DeleteCourse(Guid id)
    {
        var canDelete = await CourseService.CanDeleteCourseAsync(id);
        if (!canDelete)
        {
            await ShowAlert("Cannot delete course with enrolled students!", "danger");
            return;
        }
        
        var confirmed = await ShowConfirmDialog("Are you sure you want to delete this course?", "Confirm Delete");
        if (confirmed)
        {
            var success = await CourseService.DeleteCourseAsync(id);
            if (success)
            {
                await ShowAlert("Course deleted successfully!", "success");
                await LoadCourses();
            }
            else
            {
                await ShowAlert("Failed to delete course!", "danger");
            }
        }
    }
    
    private void CloseModal()
    {
        showModal = false;
        currentCourse = new Course();
        modalError = string.Empty;
    }
    
    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Open" => "bg-success",
            "Almost Full" => "bg-warning",
            "Full" => "bg-danger",
            _ => "bg-secondary"
        };
    }
    
    private string GetProgressBarClass(double percentage)
    {
        if (percentage >= 90) return "bg-danger";
        if (percentage >= 70) return "bg-warning";
        return "bg-success";
    }
    
    private async Task ShowAlert(string message, string type)
    {
        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }
    
    private async Task<bool> ShowConfirmDialog(string message, string title)
    {
        return await JSRuntime.InvokeAsync<bool>("showConfirm", message, title);
    }
}