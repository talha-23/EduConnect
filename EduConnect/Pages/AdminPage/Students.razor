@page "/admin/students"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using EduConnect.Services.Interfaces
@using EduConnect.Models
@inject IStudentService StudentService
@inject NavigationManager Navigation
@inject IAuthStateService AuthStateService

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Student Management</h2>
        <a href="/admin/students/add" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Student
        </a>
    </div>
    
    <!-- Search Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <label class="form-label">Search Students</label>
                    <input type="text" class="form-control"
                           placeholder="Search by name, email or student ID..."
                           @bind="searchTerm" @bind:event="oninput" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Total Students</label>
                    <input type="text" class="form-control" readonly value="@totalStudents" />
                </div>
            </div>
        </div>
    </div>
    
    <!-- Students Table -->
    <div class="card">
        <div class="card-body">
            @if (isLoading)
            {
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (!filteredStudents.Any())
            {
                <div class="alert alert-info text-center">
                    No students found.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Student ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Semester</th>
                                <th>CGPA</th>
                                <th>Department</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in filteredStudents)
                            {
                                <tr>
                                    <td>@student.StudentId</td>
                                    <td>@student.FullName</td>
                                    <td>@student.Email</td>
                                    <td>Semester @student.Semester</td>
                                    <td>
                                        <span class="badge @GetCgpaBadgeClass(student.CGPA)">
                                            @student.CGPA.ToString("F2")
                                        </span>
                                    </td>
                                    <td>@student.Department</td>
                                    <td>
                                        <a href="/admin/students/@student.Id" class="btn btn-sm btn-info me-1" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/admin/students/edit/@student.Id" class="btn btn-sm btn-warning me-1" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteStudent(student.Id)" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Student> students = new();
    private List<Student> filteredStudents = new();
    private string searchTerm = string.Empty;
    private bool isLoading = true;
    private int totalStudents = 0;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadStudents();
    }
    
    private async Task LoadStudents()
    {
        isLoading = true;
        students = await StudentService.GetAllStudentsAsync();
        filteredStudents = students;
        totalStudents = students.Count;
        isLoading = false;
        StateHasChanged();
    }
    
    protected override async Task OnParametersSetAsync()
    {
        await FilterStudents();
    }
    
    private async Task FilterStudents()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredStudents = students;
        }
        else
        {
            filteredStudents = await StudentService.SearchStudentsAsync(searchTerm);
        }
        totalStudents = filteredStudents.Count;
        StateHasChanged();
    }
    
    private async Task DeleteStudent(Guid id)
    {
        var canDelete = await StudentService.CanDeleteStudentAsync(id);
        
        if (!canDelete)
        {
            await ShowAlert("Cannot delete student with active enrollments!", "danger");
            return;
        }
        
        var confirmed = await ShowConfirmDialog("Are you sure you want to delete this student?", "Confirm Delete");
        if (confirmed)
        {
            var success = await StudentService.DeleteStudentAsync(id);
            if (success)
            {
                await ShowAlert("Student deleted successfully!", "success");
                await LoadStudents();
                await FilterStudents();
            }
            else
            {
                await ShowAlert("Failed to delete student!", "danger");
            }
        }
    }
    
    private string GetCgpaBadgeClass(double cgpa)
    {
        if (cgpa >= 3.5) return "bg-success";
        if (cgpa >= 3.0) return "bg-info";
        if (cgpa >= 2.5) return "bg-warning";
        return "bg-danger";
    }
    
    private async Task ShowAlert(string message, string type)
    {
        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }
    
    private async Task<bool> ShowConfirmDialog(string message, string title)
    {
        return await JSRuntime.InvokeAsync<bool>("showConfirm", message, title);
    }
    
    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;
}