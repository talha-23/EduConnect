@page "/admin/students"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using EduConnect.Services.Interfaces
@using EduConnect.Models
@inject IStudentService StudentService
@inject IStudentEnrollmentValidator StudentEnrollmentValidator
@inject IJSRuntime JSRuntime

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Student Management</h2>
        <button class="btn btn-primary" @onclick="ShowAddModal">
            <i class="bi bi-plus-circle"></i> Add New Student
        </button>
    </div>

    <!-- Search Box -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <div class="input-group">
                        <input type="text"
                               class="form-control"
                               placeholder="Search by name, email, or student ID..."
                               @bind="searchTerm"
                               @bind:event="oninput"
                               @onkeyup="PerformSearch" />
                        <button class="btn btn-primary" @onclick="PerformSearch">
                            <i class="bi bi-search"></i> Search
                        </button>
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <button class="btn btn-secondary" @onclick="ClearSearch">
                                <i class="bi bi-x-circle"></i> Clear
                            </button>
                        }
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <span class="text-muted">Total Students: @totalStudents</span>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (filteredStudents.Count == 0)
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle"></i> No students found.
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <span> Try a different search term.</span>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Student ID</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Semester</th>
                        <th>CGPA</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in filteredStudents)
                    {
                        <tr>
                            <td>@student.StudentId</td>
                            <td>@student.FullName</td>
                            <td>@student.Email</td>
                            <td>@student.Department</td>
                            <td>@student.Semester</td>
                            <td>@student.CGPA.ToString("F2")</td>
                            <td>
                                <button class="btn btn-sm btn-info me-1" @onclick="() => ViewStudentDetails(student)">
                                    <i class="bi bi-eye"></i> View
                                </button>
                                <button class="btn btn-sm btn-warning me-1" @onclick="() => EditStudent(student)">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteStudent(student.Id)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Add/Edit Modal -->
    @if (showModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@(isEditing ? "Edit Student" : "Add New Student")</h5>
                        <button type="button" class="btn-close" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(modalError))
                        {
                            <div class="alert alert-danger">@modalError</div>
                        }
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Student ID *</label>
                                <input type="text" class="form-control" @bind="currentStudent.StudentId" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Full Name *</label>
                                <input type="text" class="form-control" @bind="currentStudent.FullName" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email *</label>
                                <input type="email" class="form-control" @bind="currentStudent.Email" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Department</label>
                                <select class="form-select" @bind="currentStudent.Department">
                                    <option value="">Select Department</option>
                                    <option value="Computer Science">Computer Science</option>
                                    <option value="Software Engineering">Software Engineering</option>
                                    <option value="Information Technology">Information Technology</option>
                                    <option value="Data Science">Data Science</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Semester</label>
                                <input type="number" class="form-control" @bind="currentStudent.Semester" min="1" max="8" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">CGPA</label>
                                <input type="number" step="0.01" class="form-control" @bind="currentStudent.CGPA" min="0" max="4" />
                            </div>
                        </div>
                        @if (!isEditing)
                        {
                            <div class="alert alert-info">
                                <small>Default password will be set to "default123". Student can change it after first login.</small>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="SaveStudent">Save</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- View Student Details Modal -->
    @if (showViewModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-info text-white">
                        <h5 class="modal-title">Student Details</h5>
                        <button type="button" class="btn-close" @onclick="CloseViewModal"></button>
                    </div>
                    <div class="modal-body">
                        @if (selectedStudent != null)
                        {
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong>Student ID:</strong> @selectedStudent.StudentId</p>
                                    <p><strong>Full Name:</strong> @selectedStudent.FullName</p>
                                    <p><strong>Email:</strong> @selectedStudent.Email</p>
                                    <p><strong>Department:</strong> @selectedStudent.Department</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong>Semester:</strong> @selectedStudent.Semester</p>
                                    <p><strong>CGPA:</strong> @selectedStudent.CGPA.ToString("F2")</p>
                                    <p>
                                        <strong>Status:</strong>
                                        <span class="badge bg-success">Active</span>
                                    </p>
                                </div>
                            </div>
                            <hr />
                            <h6>Enrolled Courses</h6>
                            @if (enrolledCourses == null || !enrolledCourses.Any())
                            {
                                <p class="text-muted">No courses enrolled.</p>
                            }
                            else
                            {
                                <div class="list-group">
                                    @foreach (var course in enrolledCourses)
                                    {
                                        <div class="list-group-item">
                                            <strong>@course.Code</strong> - @course.Title
                                            <span class="badge bg-secondary float-end">@course.CreditHours credits</span>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseViewModal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Student> allStudents = new();
    private List<Student> filteredStudents = new();
    private bool isLoading = true;
    private bool showModal = false;
    private bool showViewModal = false;
    private bool isEditing = false;
    private Student currentStudent = new();
    private Student? selectedStudent = null;
    private List<Course> enrolledCourses = new();
    private string modalError = string.Empty;
    private string searchTerm = string.Empty;
    private int totalStudents = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadStudents();
    }

    private async Task LoadStudents()
    {
        isLoading = true;
        allStudents = await StudentService.GetAllStudentsAsync();
        filteredStudents = allStudents;
        totalStudents = allStudents.Count;
        isLoading = false;
        StateHasChanged();
    }

    private async Task PerformSearch()
    {
        isLoading = true;
        
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredStudents = allStudents;
        }
        else
        {
            // Call the service's search method
            filteredStudents = await StudentService.SearchStudentsAsync(searchTerm);
        }
        
        totalStudents = filteredStudents.Count;
        isLoading = false;
        StateHasChanged();
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        await PerformSearch();
    }

    private void ShowAddModal()
    {
        currentStudent = new Student();
        isEditing = false;
        modalError = string.Empty;
        showModal = true;
    }

    private void EditStudent(Student student)
    {
        currentStudent = new Student
        {
            Id = student.Id,
            StudentId = student.StudentId,
            FullName = student.FullName,
            Email = student.Email,
            Password = student.Password,
            Semester = student.Semester,
            CGPA = student.CGPA,
            Department = student.Department
        };
        isEditing = true;
        modalError = string.Empty;
        showModal = true;
    }

    private async Task ViewStudentDetails(Student student)
    {
        selectedStudent = student;
        
        // Load enrolled courses for this student using the validator
        if (StudentEnrollmentValidator != null)
        {
            enrolledCourses = await StudentEnrollmentValidator.GetStudentEnrolledCoursesAsync(student.Id);
        }
        
        showViewModal = true;
        StateHasChanged();
    }

    private void CloseViewModal()
    {
        showViewModal = false;
        selectedStudent = null;
        enrolledCourses = new();
    }

    private async Task SaveStudent()
    {
        try
        {
            // Validation
            if (string.IsNullOrWhiteSpace(currentStudent.StudentId))
                throw new Exception("Student ID is required");
            
            if (string.IsNullOrWhiteSpace(currentStudent.FullName))
                throw new Exception("Student name is required");
            
            if (string.IsNullOrWhiteSpace(currentStudent.Email))
                throw new Exception("Email is required");
            
            if (!currentStudent.Email.Contains("@"))
                throw new Exception("Invalid email format");
            
            if (currentStudent.Semester < 1 || currentStudent.Semester > 8)
                throw new Exception("Semester must be between 1 and 8");
            
            if (currentStudent.CGPA < 0 || currentStudent.CGPA > 4)
                throw new Exception("CGPA must be between 0 and 4");

            if (isEditing)
            {
                await StudentService.UpdateStudentAsync(currentStudent);
                await ShowAlert("Student updated successfully!", "success");
            }
            else
            {
                await StudentService.AddStudentAsync(currentStudent);
                await ShowAlert("Student added successfully!", "success");
            }
            
            CloseModal();
            await LoadStudents();
            await PerformSearch(); // Refresh search results
        }
        catch (Exception ex)
        {
            modalError = ex.Message;
        }
    }

    private async Task DeleteStudent(Guid id)
    {
        // Check if student can be deleted using the validator
        var canDelete = await StudentEnrollmentValidator.CanDeleteStudentAsync(id);
        if (!canDelete)
        {
            await ShowAlert("Cannot delete student with enrolled courses!", "danger");
            return;
        }
        
        var confirmed = await ShowConfirmDialog("Are you sure you want to delete this student?", "Confirm Delete");
        if (confirmed)
        {
            var success = await StudentService.DeleteStudentAsync(id);
            if (success)
            {
                await ShowAlert("Student deleted successfully!", "success");
                await LoadStudents();
                await PerformSearch();
            }
            else
            {
                await ShowAlert("Failed to delete student!", "danger");
            }
        }
    }

    private void CloseModal()
    {
        showModal = false;
        currentStudent = new Student();
        modalError = string.Empty;
    }

    private async Task ShowAlert(string message, string type)
    {
        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }

    private async Task<bool> ShowConfirmDialog(string message, string title)
    {
        return await JSRuntime.InvokeAsync<bool>("showConfirm", message, title);
    }
}