@page "/unauthorized"
@using EduConnect.Services.Interfaces
@inject IAuthStateService AuthStateService
@inject NavigationManager NavigationManager

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Access Denied</h4>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size: 64px; color: #dc3545;"></i>
                    </div>
                    <h5>You do not have permission to access this page.</h5>
                    <p class="text-muted">Please contact your administrator if you believe this is an error.</p>
                    <a href="/dashboard" class="btn btn-primary">Return to Dashboard</a>
                    <button class="btn btn-outline-secondary ms-2" @onclick="Logout">Logout</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private void Logout()
    {
        AuthStateService.Logout();
        NavigationManager.NavigateTo("/login", true);
    }
}