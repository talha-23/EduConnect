@page
@using System.Diagnostics
@{
    var errorMessage = "An error occurred while processing your request.";
    var showRequestId = false;
    var requestId = Activity.Current?.Id ?? HttpContext.TraceIdentifier;
    
    if (!string.IsNullOrEmpty(requestId))
    {
        showRequestId = true;
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error - EduConnect</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">
                        <h4 class="mb-0">Error</h4>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <i class="bi bi-exclamation-triangle-fill" style="font-size: 64px; color: #dc3545;"></i>
                        </div>
                        <h5 class="text-center">@errorMessage</h5>
                        
                        @if (showRequestId)
                        {
                            <p class="text-muted text-center small">
                                <strong>Request ID:</strong> <code>@requestId</code>
                            </p>
                        }
                        
                        <div class="text-center mt-4">
                            <a href="/dashboard" class="btn btn-primary">Return to Dashboard</a>
                            <button onclick="location.reload()" class="btn btn-secondary">Reload Page</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>