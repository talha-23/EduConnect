@page "/faculty/courses"
@attribute [Authorize(Roles = "Faculty")]
@using Microsoft.AspNetCore.Authorization
@using EduConnect.Services.Interfaces
@using EduConnect.Models
@* @inject ICourseService CourseService *@

<div class="container mt-4">
    <h2 class="mb-4">My Assigned Courses</h2>
    
    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!assignedCourses.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> You don't have any assigned courses yet.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var course in assignedCourses)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">@course.Code - @course.Title</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                <strong>Credits:</strong> @course.CreditHours<br />
                                <strong>Enrolled Students:</strong> @course.CurrentEnrollment / @course.MaxCapacity<br />
                                <strong>Schedule:</strong> TBD<br />
                                <strong>Room:</strong> TBD
                            </p>
                            <div class="progress mb-2">
                                <div class="progress-bar bg-success" style="width: @course.GetEnrollmentPercentage()%">
                                    @course.GetEnrollmentPercentage().ToString("F0")% Full
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <a href="/faculty/grades?courseId=@course.Id" class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-pencil-square"></i> Manage Grades
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Course> assignedCourses = new();
    private bool isLoading = true;
    
    // For demo, assign some courses to faculty
    // In real implementation, this would come from database
    private List<Guid> facultyCourseIds = new() { }; // Add logic to get faculty's courses
    
    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        var allCourses = await CourseService.GetAllCoursesAsync();
        
        // For demo, assign first 2 courses to faculty
        assignedCourses = allCourses.Take(2).ToList();
        
        isLoading = false;
        StateHasChanged();
    }
    
    [Inject]
    private ICourseService CourseService { get; set; } = default!;
}